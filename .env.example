# Firebase Configuration
# Get these values from your Firebase Console project settings
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcd1234efgh5678

# Google Sign-In Configuration
# Get this OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_WEB_CLIENT_ID=885163617614-dlc8fqdenhnh7rq01ca9qqcc8pj1pmst.apps.googleusercontent.com

# Cloudinary Configuration
# Get these from your Cloudinary dashboard at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Firestore Database Configuration
FIRESTORE_DATABASE_ID=default

# App Configuration
APP_ENV=development
# production or development for Firebase environment
